# .env.example — Copy thành .env và điền thông tin thật
# KHÔNG commit .env lên Git!

# ── Database ──────────────────────────────────────────────────
DB_SERVER=localhost
DB_NAME=BIG_DATA
DB_USER=
DB_PASS=

# ── Scraper Settings ──────────────────────────────────────────
MAX_CONCURRENT=3
MAX_PAGES_PER_HOTEL=10
DELAY_MIN=2.5
DELAY_MAX=6.0
PAGE_DELAY_MIN=1.5
PAGE_DELAY_MAX=3.5
BATCH_PAUSE_MIN=15.0
BATCH_PAUSE_MAX=30.0
BROWSER_RESTART_EACH=100

# ── Proxy Settings ────────────────────────────────────────────
PROXY_ENABLED=false
PROXY_PROVIDER=brightdata

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/etl.log

# ── Report ────────────────────────────────────────────────────
REPORT_DIR=reports